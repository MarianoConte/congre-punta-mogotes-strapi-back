{
  "kind": "collectionType",
  "collectionName": "territorios",
  "info": {
    "singularName": "territorio",
    "pluralName": "territorios",
    "displayName": "Territorio",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Numero": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 4
    },
    "Notas": {
      "type": "text"
    },
    "Manzanas": {
      "type": "json"
    },
    "Foto": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "salidas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::salida.salida",
      "mappedBy": "territorio"
    }
  }
}
